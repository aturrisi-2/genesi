# Genesi Environment Configuration
# Copy this file to /etc/genesi.env on VPS and fill in your API keys

# Weather API (OpenWeatherMap)
# Get your free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# News API (NewsAPI)
# Get your free key at: https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# OpenAI API (for psychological branch)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# AWS Bedrock Configuration (for image generation)
# AWS region where Bedrock is available (e.g., eu-west-1, us-east-1)
AWS_REGION=eu-west-1
# AWS Access Key ID
# Get your credentials at: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
# S3 bucket for storing generated images
# The bucket must exist and be writable by your AWS credentials
AWS_S3_BUCKET=genesi-generated-images
# Bedrock Model ID (default: Stable Diffusion XL)
BEDROCK_MODEL=stability.stable-diffusion-xl-v0

# Optional: Database configuration
# DATABASE_URL=postgresql://user:password@localhost:5432/genesi

# Optional: Redis for caching
# REDIS_URL=redis://localhost:6379

# Optional: Log level
# LOG_LEVEL=INFO
